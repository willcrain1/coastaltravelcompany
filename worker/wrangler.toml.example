# wrangler.toml — generated by deploy-worker.sh / deploy-worker-preprod.sh, do not edit manually.
# This example shows the structure. The real file is gitignored.

name = "your-worker-name"
main = "cloudflare-worker.js"
compatibility_date = "2024-09-23"

[[kv_namespaces]]
binding = "KV"
id = "your-kv-namespace-id"   # filled in by deploy-worker.sh

[[d1_databases]]
binding = "DB"
database_name = "CTC_PROJECTS"
database_id = "your-d1-database-id"  # filled in by deploy-worker.sh

[triggers]
crons = ["0 * * * *"]   # hourly — runs automation checks (inquiry auto-reply, follow-ups, reminders)

# ── Preprod environment (populated by deploy-worker-preprod.sh) ──────────────
# Deploy with: npx wrangler deploy --env preprod

[env.preprod]
name = "your-worker-name-preprod"

[env.preprod.vars]
ALLOWED_ORIGIN = "https://preprod.coastaltravelcompany.com"

[[env.preprod.kv_namespaces]]
binding = "KV"
id = "your-preprod-kv-namespace-id"   # CTC_AUTH_PREPROD — filled in by deploy-worker-preprod.sh

[[env.preprod.d1_databases]]
binding = "DB"
database_name = "ctc-preprod"
database_id = "your-preprod-d1-database-id"  # filled in by deploy-worker-preprod.sh

# ── Required secrets ────────────────────────────────────────────────────────
# Set each secret once via: wrangler secret put <NAME>
# For preprod: wrangler secret put <NAME> --env preprod
#
#   wrangler secret put JWT_SECRET
#     → Enter a long random string (e.g. openssl rand -hex 32).
#       Used to sign 7-day auth tokens. Rotate if compromised.
#       Use a DIFFERENT value for preprod.
#
#   wrangler secret put RESEND_API_KEY
#     → Already set from contact form setup (item 1). Can reuse prod key for preprod.
#
#   wrangler secret put STRIPE_SECRET_KEY
#     → Use Stripe TEST MODE key (sk_test_...) for preprod.
#
#   wrangler secret put STRIPE_WEBHOOK_SECRET
#     → Register a separate webhook endpoint for preprod in Stripe dashboard.
#
#   wrangler secret put GITHUB_TOKEN
#     → Fine-grained personal access token (github.com → Settings → Developer settings →
#       Fine-grained tokens). Required scopes for this repo only:
#         Contents: Read and write   (read/update site HTML files)
#         Pages: Read                (poll deployment build status)
#       Used by the CMS content editor (item 18) to read/commit site pages via the
#       GitHub Contents API. Same token works for both prod and preprod workers since
#       both edit the same repo. Never use a classic token with broad repo:* scope.
#
# ── Optional variables (set in Cloudflare dashboard → Worker → Settings → Variables) ──
#
#   GOOGLE_CLIENT_ID = "123456789-abc.apps.googleusercontent.com"
#     → Enables Google Sign-In on login.html.
#       Create OAuth 2.0 credentials at console.cloud.google.com/apis/credentials.
#       Add https://coastaltravelcompany.com AND https://preprod.coastaltravelcompany.com
#       to "Authorized JavaScript origins".
#       The worker uses this to verify Google ID tokens.
#       Also update the GOOGLE_CLIENT_ID constant in login.html.
